# ============================================================
# QuietGate
# Example environment file
# ============================================================

# Your server timezone.
# Examples:
# TZ=Etc/UTC
# TZ=Europe/London
# TZ=America/New_York
TZ=Etc/UTC

# Your server's Tailscale IPv4 address.
# Find it with:
# tailscale ip -4
#
# Example:
# TAILSCALE_IP=100.x.x.x
TAILSCALE_IP=100.x.x.x

# Quick-start private domain.
#
# For first-time setup, use:
# BASE_DOMAIN=YOUR_TAILSCALE_IP.nip.io
#
# Example:
# BASE_DOMAIN=100.x.x.x.nip.io
#
# This avoids editing hosts files and still points to your private Tailscale IP.
BASE_DOMAIN=100.x.x.x.nip.io

# Directory for persistent app data.
APPDATA_DIR=./appdata

# Homepage config directory.
HOMEPAGE_CONFIG_DIR=./config/homepage

# Hostnames allowed by Homepage.
#
# This should match the Homepage URL created from BASE_DOMAIN.
#
# Example:
# HOMEPAGE_ALLOWED_HOSTS=homepage.100.x.x.x.nip.io
HOMEPAGE_ALLOWED_HOSTS=homepage.100.x.x.x.nip.io
